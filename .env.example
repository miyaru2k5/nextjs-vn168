# Database (Drizzle + PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/beauty_spa?schema=public"

# AI
OPENAI_API_KEY="sk-..."

# NextAuth
AUTH_SECRET="change-this-in-production"
AUTH_URL="http://localhost:3000"

# Stripe (optional for payments demo)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_PLUS_MONTHLY_PRICE_ID=
NEXT_PUBLIC_PLUS_YEARLY_PRICE_ID=
NEXT_PUBLIC_PRO_MONTHLY_PRICE_ID=
NEXT_PUBLIC_PRO_YEARLY_PRICE_ID=

# ======================
# Random Data Seeder options
# ======================
# SEED_TO_DB=true          # Insert vào database (mặc định true)
# SEED_TO_JSON=true        # Tạo file JSON vào thư mục seed-data/
#
# Trong môi trường local (development):
#   - Mặc định sẽ tạo JSON nếu SEED_TO_JSON không phải 'false'
#   - Đặt SEED_TO_JSON=true để bật tạo file JSON (rất hữu ích khi chưa có DB hoặc muốn dữ liệu cho mock)
#   - Đặt SEED_TO_DB=false nếu chỉ muốn JSON thôi
SEED_TO_JSON=true

# ======================
# Data Source Mode (for admin pages & seed loader)
# ======================
# auto  (default)  → JSON nếu có → DB nếu có DATABASE_URL → mock
# json             → Chỉ dùng file JSON đã seed (local nhanh, không cần DB)
# db               → Bắt buộc dùng PostgreSQL thật qua Drizzle
# mock             → Chỉ dùng static mock (demo)
#
# Production nên set DATA_SOURCE=db
DATA_SOURCE=auto
